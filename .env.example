# Local development app origin.
# In production, set this to the deployed browser origin for the app.
# Google OAuth should allow: <BETTER_AUTH_URL>/api/auth/callback/google
DATABASE_URL=postgres://postgres:postgres@localhost:5432/recipe_app
BETTER_AUTH_SECRET=replace-with-a-32-character-secret-value
BETTER_AUTH_URL=http://localhost:5173
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
